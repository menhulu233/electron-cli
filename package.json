{
  "name": "electron-vite-vue3-enterprise",
  "version": "1.0.0",
  "description": "Enterprise Electron + Vue3 + Vite Template",
  "main": "dist-electron/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "rimraf dist-electron && concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "test": "vitest run",
    "prepare": "husky",
    "compile:electron": "tsc --project electron-tsconfig.json",
    "dist": "npm run build && npm run compile:electron && electron-builder",
    "dist:win": "npm run build && npm run compile:electron && electron-builder --win",
    "dist:mac": "npm run build && npm run compile:electron && electron-builder --mac",
    "dist:linux": "npm run build && npm run compile:electron && electron-builder --linux"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.22",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.1.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-i18n": "^9.9.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.35",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.6",
    "wait-on": "^7.2.0"
  }
}
